# ==============================================================================
# .env.example  —  credentials & data-access config for the 2021a SSH mapping
#                  OSE validation run (sverdrup OI vs the challenge BASELINE).
#
# USAGE:
#   1.  cp .env.example .env
#   2.  chmod 600 .env
#   3.  Fill in your AVISO+ username and password below (in .env, NOT here).
#   4.  NEVER commit .env. It is gitignored. This .env.example IS committed,
#       and must therefore contain NO real secrets — only placeholders.
#
# The loader should read .env (e.g. python-dotenv) and fail loudly with a clear
# message if AVISO_USERNAME / AVISO_PASSWORD are empty when an authenticated
# access path is selected.
# ==============================================================================


# ------------------------------------------------------------------------------
# AVISO+ credentials  (https://www.aviso.altimetry.fr/ — "My AVISO+" account)
# ------------------------------------------------------------------------------
# These are your AVISO+ website login/password. The same credentials work for
# the AVISO+ THREDDS Data Server (OPeNDAP/FileServer over HTTPS) and for
# FTP/SFTP. Used as HTTP Basic Auth against the THREDDS endpoint.
#
# NOTE (per AVISO docs): the "Aviso-Cnes Data Center" (aviso-data-center.cnes.fr)
# uses a SEPARATE login from the main AVISO+ THREDDS server. The 2021a data
# challenge products live on the main AVISO+ THREDDS (and a temporary MEOM
# mirror), so the main AVISO+ credentials are the ones to use here. If you ever
# point at the CNES data center, that needs its own pair (see the optional
# block further down).

AVISO_USERNAME=
AVISO_PASSWORD=


# ------------------------------------------------------------------------------
# Data access method
# ------------------------------------------------------------------------------
# Preferred: THREDDS (OPeNDAP / FileServer over HTTPS, authenticated with the
# AVISO_USERNAME/AVISO_PASSWORD above). This is the THREDDS-not-FTP path you
# asked for. Set to "thredds", "ftp", or "meom_mirror".
#
#   thredds      -> authenticated AVISO+ THREDDS (recommended)
#   meom_mirror  -> unauthenticated MEOM-Grenoble opendap mirror (no creds;
#                   "temporarily available" per the challenge README — may
#                   disappear, but is the simplest path while it lasts)
#   ftp          -> authenticated AVISO+ FTP/SFTP (fallback if THREDDS auth
#                   or OPeNDAP gives trouble)

AVISO_ACCESS_METHOD=thredds


# ------------------------------------------------------------------------------
# THREDDS endpoint  (VERIFY against the live server before trusting — see note)
# ------------------------------------------------------------------------------
# The exact catalog path for the 2021a challenge products must be confirmed by
# browsing the live AVISO+ THREDDS catalog (the dataset DOI is
# 10.24400/527896/a01-2021.005). The base below is the standard AVISO+ THREDDS
# root; the per-product catalog/dataset path is appended by the data adapter
# after it has been verified. DO NOT hardcode a deep path that hasn't been
# confirmed to resolve — verifying the catalog URL is the data adapter's first
# task.
#
# OPeNDAP auth for THREDDS is typically done EITHER via HTTP Basic Auth in the
# request, OR via a ~/.netrc + ~/.dodsrc pair if accessed through the netCDF-C
# / pydap OPeNDAP stack. The adapter should support whichever the live server
# requires; .netrc is generated from these vars if needed (and also gitignored).

AVISO_THREDDS_BASE_URL=https://tds.aviso.altimetry.fr/thredds
# Optional explicit catalog override once verified (leave blank to let the
# adapter discover/confirm it):
AVISO_THREDDS_CATALOG_URL=


# ------------------------------------------------------------------------------
# MEOM-Grenoble mirror (unauthenticated fallback, no credentials needed)
# ------------------------------------------------------------------------------
# The 2021a challenge README points here as a temporary mirror. No auth. Use by
# setting AVISO_ACCESS_METHOD=meom_mirror. Verify it still resolves before
# relying on it.

MEOM_OPENDAP_BASE_URL=https://ige-meom-opendap.univ-grenoble-alpes.fr/thredds/catalog/meomopendap/extract/MEOM/OCEAN_DATA_CHALLENGES/2021a-SSH-mapping-OSE


# ------------------------------------------------------------------------------
# AVISO+ FTP/SFTP fallback (only if AVISO_ACCESS_METHOD=ftp)
# ------------------------------------------------------------------------------
# Reuses AVISO_USERNAME / AVISO_PASSWORD above. Host shown is the standard
# AVISO+ FTP host; confirm against AVISO docs if it fails.

AVISO_FTP_HOST=ftp-access.aviso.altimetry.fr
AVISO_FTP_PROTOCOL=sftp   # sftp or ftp


# ------------------------------------------------------------------------------
# Local data layout
# ------------------------------------------------------------------------------
# Where downloaded challenge data lands locally. Keep OUT of git (the data is
# large and not ours to redistribute). Mirrors the challenge's dc_obs / dc_maps
# structure under this root.

DC_DATA_ROOT=./data/2021a_ssh_mapping_ose


# ------------------------------------------------------------------------------
# OPTIONAL: Aviso-CNES Data Center (SEPARATE login — only if you ever use it)
# ------------------------------------------------------------------------------
# Per AVISO docs the CNES data center (aviso-data-center.cnes.fr) uses a
# DIFFERENT individual login/password from the main AVISO+ site. Not needed for
# the 2021a challenge data; included only so the distinction is documented and
# nobody pastes the wrong pair. Leave blank unless specifically required.

AVISO_CNES_USERNAME=
AVISO_CNES_PASSWORD=
